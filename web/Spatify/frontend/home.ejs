<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Spatify | Agent Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'sput-black': '#000000',
                        'sput-dark': '#121212',
                        'sput-green': '#1DB954',
                        'sput-gray': '#282828',
                        'sput-light': '#B3B3B3',
                    },
                    fontFamily: { 'sans': ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <style>
        body { background-color: #000000; color: #FFFFFF; font-family: 'Inter', sans-serif; }
        .sidebar-link:hover { background-color: #1A1A1A; }
        .table-row:hover { background-color: rgba(255, 255, 255, 0.03); }
        select {
            appearance: none;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='rgb(179,179,179)' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 1rem center;
            background-size: 1.2em;
        }
    </style>
</head>
<body class="flex h-screen overflow-hidden">

    <aside class="w-64 bg-black flex flex-col p-6 border-r border-white/10">
        <div class="flex items-center gap-3 px-2 mb-10">
            <div class="w-10 h-10 bg-sput-green rounded-lg flex items-center justify-center text-black font-extrabold text-2xl">S</div>
            <h1 class="text-xl font-bold tracking-tight text-white">Spatify</h1>
        </div>

        <nav class="flex-1 space-y-2">
            <p class="text-[10px] text-sput-light font-bold uppercase tracking-widest px-3 mb-2 opacity-50">Yönetim</p>
            <a href="/home" class="sidebar-link flex items-center gap-4 px-3 py-2.5 rounded-lg text-sput-green bg-white/5 transition font-semibold">
                <span>📁</span> Katalog Denetimi
            </a>
            <a href="/upload" class="sidebar-link flex items-center gap-4 px-3 py-2.5 rounded-lg text-sput-light transition">
                <span>👤</span> Sanatçı Yönetimi
            </a>
        </nav>

        <div class="bg-sput-dark p-5 rounded-2xl border border-white/5">
            <p class="text-[10px] font-bold text-sput-green mb-2 uppercase tracking-widest">Sistem Durumu</p>
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-sput-green animate-pulse"></span>
                <span class="text-xs text-white font-medium">PostgreSql aktif</span>
            </div>
        </div>
    </aside>

    <main class="flex-1 flex flex-col overflow-hidden">
        
        <header class="h-20 flex items-center justify-between px-10 bg-sput-black border-b border-white/5">
            <div>
                <h2 class="text-xs font-bold text-sput-light uppercase tracking-widest">Panel</h2>
                <p class="text-xl font-bold text-white tracking-tight italic">Anasayfa</p>
            </div>

            <div class="flex items-center gap-6">
                <div class="text-right">
                    <p class="text-[10px] text-sput-green font-bold tracking-widest uppercase">Kullanıcı</p>
                    <p class="text-sm font-semibold text-white tracking-tight"><%= site_isim %></p>
                </div>
                <div class="relative">
                    <img src="https://api.dicebear.com/7.x/initials/svg?seed=<%= site_isim %>&backgroundColor=1DB954" 
                         class="w-11 h-11 rounded-full border border-white/10 p-0.5 bg-sput-gray" alt="Avatar">
                </div>
                <a href="/logout" class="text-[10px] font-bold text-red-500 hover:text-red-400 uppercase tracking-tighter border border-red-500/20 px-3 py-1 rounded">ÇIKIŞ YAP</a>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto p-10">
            
            <div class="mb-8">
                <h2 class="text-3xl font-bold text-white">Hoş Geldin, <%= site_isim.split('@')[0] %></h2>
                <p class="text-sput-light text-sm mt-1">Yeni çıkan bütün hit şarkılar burda!</p>
            </div>

            <section class="bg-sput-dark rounded-2xl p-6 mb-10 border border-white/5 shadow-xl">
                <form action="/home" method="GET" class="grid grid-cols-12 gap-4 items-end">
                    <div class="col-span-12 lg:col-span-7">
                        <label class="block text-[10px] font-bold text-sput-light mb-2 uppercase">Katalogda Ara</label>
                        <input type="text" name="query" value="<%= aranan_kelime %>" 
                               placeholder="Sanatçı veya şarkı ismi..." 
                               class="w-full bg-black border border-white/10 rounded-xl p-4 text-sm text-white focus:border-sput-green outline-none transition">
                    </div>

                    <div class="col-span-12 lg:col-span-3">
                        <label class="block text-[10px] font-bold text-sput-light mb-2 uppercase">Sıralama Ölçütü</label>
                        <select name="sort_by" class="w-full bg-black border border-white/10 rounded-xl p-4 text-sm text-sput-light outline-none cursor-pointer">
                            <option value="id" <%= siralama === 'id' ? 'selected' : '' %>>Sistem ID</option>
                            <option value="artist" <%= siralama === 'artist' ? 'selected' : '' %>>Sanatçı Adı</option>
                            <option value="song_title" <%= siralama === 'song_title' ? 'selected' : '' %>>Şarkı Başlığı</option>
                        </select>
                    </div>

                    <div class="col-span-12 lg:col-span-2">
                        <button type="submit" class="w-full bg-sput-green text-black font-extrabold py-4 rounded-xl hover:bg-[#1ed760] transition shadow-lg shadow-sput-green/10">
                            ARA
                        </button>
                    </div>
                </form>
            </section>

            <div class="bg-sput-dark rounded-2xl overflow-hidden border border-white/5 shadow-2xl">
                <table class="w-full text-left text-sm">
                    <thead>
                        <tr class="text-[10px] text-sput-light font-bold uppercase tracking-widest border-b border-white/10">
                            <th class="px-8 py-5 w-24">#ID</th> <th class="px-8 py-5">Sanatçı</th>
                            <th class="px-8 py-5">Şarkı İsmi</th>
                            <th class="px-8 py-5 text-right">Durum</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        <% if (db_sonucu.length > 0) { %>
                            <% db_sonucu.forEach(function(item) { %>
                                <tr class="table-row transition group">
                                    <td class="px-8 py-5">
                                        <div class="flex items-center gap-4">
                                            <span class="text-sput-light font-mono text-xs opacity-50 w-4"><%= item.id %></span>
                                            <div class="w-12 h-12 flex-shrink-0 shadow-lg">
                                                <img src="/assets/covers/<%= item.cover_image %>" 
                                                     class="w-full h-full object-cover rounded-md border border-white/5" 
                                                     alt="Kapak">
                                            </div>
                                        </div>
                                    </td>

                                    <td class="px-8 py-5 font-bold text-white group-hover:text-sput-green transition"><%= item.artist %></td>
                                    
                                    <td class="px-8 py-5">
                                        <div class="flex items-center gap-3">
                                            <span class="font-bold text-white/90 tracking-tight"><%= item.song_title %></span>
                                            
                                            <% if (item.is_released===false) { %>
                                                <a href="/assets/leaked_song6542345246764.wav" download 
                                                   class="flex items-center gap-1.5 px-2 py-0.5 bg-red-500/10 border border-red-500/20 rounded text-[9px] text-red-500 hover:bg-red-500 hover:text-white transition-all font-black uppercase">
                                                    RAW_DATA.MP3
                                                </a>
                                            <% } %>
                                        </div>
                                    </td>

                                    <td class="px-8 py-5 text-right">
                                        <% if (item.is_released===true) { %>
                                            <span class="text-[10px] font-bold text-sput-green bg-sput-green/10 px-2 py-1 rounded border border-sput-green/20">
                                                YAYINDA
                                            </span>
                                        <% } else { %>
                                            <div class="flex flex-col items-end gap-1">
                                                <span class="text-[10px] font-bold text-red-500 bg-red-500/10 px-2 py-1 rounded border border-red-500/20 animate-pulse">
                                                    SIZDIRILDI
                                                </span>
                                                <span class="text-[8px] text-sput-light opacity-40 uppercase tracking-tighter italic">Kanıt Mevcut</span>
                                            </div>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="px-8 py-20 text-center text-sput-light italic opacity-40">
                                    Eşleşen kayıt bulunamadı. Lütfen SQL sorgunuzu kontrol edin.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <footer class="mt-10 text-center text-[10px] text-sput-light opacity-30 uppercase tracking-[0.3em]">
                Spatify Internal Management System v2.1
            </footer>
        </div>
    </main>

</body>
</html>