# ==============================================================================
# Order 66: Execute the Query - CTF Challenge
# Environment Configuration Template
# ==============================================================================
# 
# Copy this file to .env for customization:
# cp .env.example .env
#
# Note: docker-compose.yml contains sensible defaults for all variables.
# Only override variables you need to customize.
# ==============================================================================

# ==============================================================================
# PRODUCTION DEPLOYMENT VARIABLES (Most Important)
# ==============================================================================

# Frontend API URL (only needed for special configurations)
# Default: Auto-detected based on current domain
# VITE_API_URL=https://your-domain.com/api

# Database Configuration
# MYSQL_ROOT_PASSWORD=your-secure-password
# MYSQL_DATABASE=empire_todos
# MYSQL_USER=vader
# MYSQL_PASSWORD=your-secure-password

# Security Configuration  
# SECRET_KEY=your-very-secure-secret-key-change-in-production
# CTF_FLAG=SKYDAYS{YOUR_CTF_FLAG_HERE}

# ==============================================================================
# DEVELOPMENT OVERRIDES (docker-compose.override.yml recommended instead)
# ==============================================================================

# Uncomment for development
# DEBUG=true
# LOG_LEVEL=debug
# VITE_DEV_MODE=true

# ==============================================================================
# MySQL Database Configuration
# ==============================================================================

# MySQL root password (REQUIRED - Change in production!)
# MYSQL_ROOT_PASSWORD=emperor

# Database name for the application
# MYSQL_DATABASE=empire_todos

# MySQL user for the application
# MYSQL_USER=vader

# MySQL password for the application user (REQUIRED - Change in production!)
# MYSQL_PASSWORD=deathstar

# ==============================================================================
# Backend API Configuration
# ==============================================================================

# Host for the backend API server
# API_HOST=0.0.0.0

# Port for the backend API server
# API_PORT=8000

# API path prefix
# API_PREFIX=/api

# Frontend URL for CORS
# FRONTEND_URL=http://localhost:3000

# Allowed origins for CORS (JSON array format)
# ALLOWED_ORIGINS=["http://localhost:3000","http://frontend:3000","http://localhost:5173"]

# ==============================================================================
# Frontend Configuration
# ==============================================================================

# Development mode flag for frontend
# VITE_DEV_MODE=false

# Node.js version for frontend container
# NODE_VERSION=20

# Nginx version for frontend serving
# NGINX_VERSION=1.24

# ==============================================================================
# Security & Authentication
# ==============================================================================

# Secret key for JWT tokens and encryption (REQUIRED - Change in production!)
# SECRET_KEY=execute-order-66-the-empire-strikes-back

# JWT access token expiration time in minutes
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# JWT algorithm
# ALGORITHM=HS256

# ==============================================================================
# Application Configuration
# ==============================================================================

# Debug mode (false for production)
# DEBUG=false

# Logging level (debug, info, warning, error, critical)
# LOG_LEVEL=info

# Application name
# APP_NAME=Order 66 Execute the Query - CTF Challenge

# Application version
# APP_VERSION=1.0.0-CTF

# Environment (development, staging, production)
# ENVIRONMENT=production

# ==============================================================================
# Performance & Scaling Configuration
# ==============================================================================

# Number of worker processes for backend
# WORKER_PROCESSES=1

# Number of worker connections
# WORKER_CONNECTIONS=1000

# Keep-alive timeout in seconds
# KEEPALIVE_TIMEOUT=2

# Maximum request size in bytes (16MB)
# MAX_REQUEST_SIZE=16777216

# Request timeout in seconds
# REQUEST_TIMEOUT=30

# ==============================================================================
# CORS Configuration
# ==============================================================================

# Allow credentials in CORS requests
# ALLOW_CREDENTIALS=true

# Allowed HTTP methods (JSON array format)
# ALLOW_METHODS=["*"]

# Allowed HTTP headers (JSON array format)
# ALLOW_HEADERS=["*"]

# ==============================================================================
# CTF Challenge Configuration
# ==============================================================================

# The CTF flag to be hidden in the database (CHANGE FOR YOUR CTF!)
# CTF_FLAG=SKYDAYS{SKYORDER_66_HAD_TO_EXECUTED}

# Description of the CTF flag
# CTF_FLAG_DESCRIPTION=Execute Order 66 - The hidden Imperial intelligence

# Enable sample todo data insertion
# ENABLE_SAMPLE_DATA=true

# Enable CTF-specific endpoints
# ENABLE_CTF_ENDPOINTS=true

# ==============================================================================
# Health Check Configuration
# ==============================================================================

# Health check interval in seconds
# HEALTH_CHECK_INTERVAL=30

# Health check timeout in seconds
# HEALTH_CHECK_TIMEOUT=5

# Health check retry attempts
# HEALTH_CHECK_RETRIES=3
